# Copy to .env and fill in. Required vars are validated at boot by src/lib/env.ts.

# --- Required (Phase 1) ---
# Postgres connection. docker-compose maps host 5433 -> container 5432.
DATABASE_URL="postgresql://guildtool:guildtool@localhost:5433/guildtool?schema=public"
# Auth.js secret. Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me"
# Discord OAuth app (https://discord.com/developers/applications):
#   redirect URI: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_CLIENT_ID="your-discord-client-id"
AUTH_DISCORD_CLIENT_SECRET="your-discord-client-secret"

# --- Optional now; needed by the phase noted ---
# Comma-separated Discord user IDs seeded as OFFICER (run: yarn db:seed)
OFFICER_DISCORD_IDS=""
# Raid-Helper server API key + Discord server (guild) ID (Phase 2)
RAID_HELPER_API_KEY=""
RAID_HELPER_SERVER_ID=""
# Warcraft Logs v2 OAuth client (Phase 4)
WCL_CLIENT_ID=""
WCL_CLIENT_SECRET=""
# WCL guild id (numeric) for guild rank + attendance. Find it in your guild's
# WCL URL or a report's guild. The Dust = 809103.
WCL_GUILD_ID=""
# Bearer token guarding /api/cron/* (Phase 2)
CRON_SECRET=""
